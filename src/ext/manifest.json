{
  "name": "CWFGE",
  "description": "Extensión para la captura de páginas web",
  "version": "$VERSION",
  "permissions": [
    "cookies",
    "debugger",
    "contextMenus",
    "notifications",
    "scripting",
    "tabs",
    "activeTab",
    "storage",
    "unlimitedStorage",
    "webRequest"
  ],
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
  "background": {
    "service_worker": "bg.js"
  },
  "icons": {
    "32": "$ICON",
    "128": "$ICON"
  },
  "action": {
    "default_icon": {
      "32": "$ICON"
    },
    "default_title": "CWFGE",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["pdf/*", "ruffle/*"],
      "matches": ["*://*/*"]
    }
  ],
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": ["*://siaikevin.test/*", "*://siai2/*"],
      "js": ["capture-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "manifest_version": 3
}
